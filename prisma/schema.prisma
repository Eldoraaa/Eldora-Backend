generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum UserRole {
  family
  caregiver
  admin
}

enum DeviceCommandType {
  configure_wifi
  activate_local_alarm
  speak_on_dorabot
}

enum DeviceCommandStatus {
  pending
  delivered
  applied
  failed
}

enum DevicePairingRequestStatus {
  pending
  approved
  rejected
  expired
}

enum HomeMemberRole {
  home_owner
  administrator
  common_member
}

enum HomeInvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum SceneTriggerType {
  tap_to_run
  device_status_changes
  schedule
  weather_changes
  family_member_going_home
}

enum NotificationType {
  alarm
  home
  device
}

enum VoiceEmotionState {
  neutral
  calm
  happy
  sad
  anxious
  distressed
}

enum ElderReminderSource {
  voice
  caregiver
  scene
}

enum ElderReminderStatus {
  pending
  queued
  delivered
  acknowledged
  cancelled
  failed
  needs_confirmation
}

enum SceneReminderDeliveryMode {
  conversation_append
  scheduled_speak
}

// Models

model MsUser {
  id        String   @id @default(cuid())
  email     String   @unique
  googleId  String?  @unique
  name      String
  avatarUrl String?
  role      UserRole @default(family)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  elderProfileLinks TrElderProfileUser[]
  pairingRequests TrDevicePairingRequest[] @relation("PairingRequester")
  homeMemberships TrHomeMember[]
  homeInvitations TrHomeInvitation[] @relation("HomeInvitationCreator")
  notificationPreference MsNotificationPreference?
  notificationDeviceTokens MsNotificationDeviceToken[]
  notifications TrNotification[]
  notificationStates TrNotificationUserState[]
  notificationResponses TrNotificationResponse[]
  emergencyContacts MsEmergencyContact[]
  createdScenes MsScene[] @relation("SceneCreator")

  @@map("MsUser")
}

model MsEmergencyContact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  relation  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  homeId String?
  home   MsHome?  @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
  @@index([homeId, isPrimary])
  @@map("MsEmergencyContact")
}

model MsNotificationDeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  platform  String?
  deviceId  String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   MsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("MsNotificationDeviceToken")
}

model MsNotificationPreference {
  id                          String   @id @default(cuid())
  deviceAlertEnabled          Boolean  @default(true)
  dndEnabled                  Boolean  @default(false)
  dndStartTime                String?
  dndEndTime                  String?
  systemNotificationEnabled   Boolean  @default(true)
  homeAlertEnabled            Boolean  @default(true)
  fallAlertEnabled            Boolean  @default(true)
  sosAlertEnabled             Boolean  @default(true)
  deviceOfflineAlertEnabled   Boolean  @default(true)
  lowBatteryAlertEnabled      Boolean  @default(true)
  pairingRequestAlertEnabled  Boolean  @default(true)
  bulletinEnabled             Boolean  @default(true)
  fcmToken                    String?
  fcmPlatform                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  userId String @unique
  user   MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("MsNotificationPreference")
}

model MsHome {
  id            String   @id @default(cuid())
  name          String
  locationLabel String?
  address       String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members     TrHomeMember[]
  rooms       MsRoomCategory[]
  invitations TrHomeInvitation[]
  scenes      MsScene[]
  notifications TrNotification[]
  emergencyContacts MsEmergencyContact[]
  elderReminders TrElderReminder[]

  @@map("MsHome")
}

model TrHomeMember {
  id        String         @id @default(cuid())
  role      HomeMemberRole @default(common_member)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  homeId String
  home   MsHome   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  userId String
  user   MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([homeId, userId])
  @@index([userId])
  @@map("TrHomeMember")
}

model TrHomeInvitation {
  id         String               @id @default(cuid())
  email      String?
  role       HomeMemberRole       @default(common_member)
  status     HomeInvitationStatus @default(pending)
  inviteCode String               @unique
  expiresAt  DateTime
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  homeId String
  home   MsHome   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   MsUser   @relation("HomeInvitationCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([homeId, status])
  @@index([email])
  @@map("TrHomeInvitation")
}

model MsElderProfile {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userLinks TrElderProfileUser[]
  devices MsDevice[]
  voiceConversationTurns TrVoiceConversationTurn[]
  memoryFacts MsElderMemoryFact[]
  contextSummary MsElderContextSummary?
  elderReminders TrElderReminder[]
  sceneReminderDeliveries TrSceneReminderDelivery[]

  @@map("MsElderProfile")
}

model TrElderProfileUser {
  elderProfileId String
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  userId String
  user   MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([elderProfileId, userId])
  @@index([userId])
  @@map("TrElderProfileUser")
}

model MsDevice {
  id                         String    @id @default(cuid())
  deviceId                   String    @unique
  deviceKey                  String    @unique
  name                       String?
  isOnline                   Boolean   @default(false)
  lastSeen                   DateTime?
  batteryLevel               Int?
  isCharging                 Boolean   @default(false)
  wifiSsid                   String?
  wifiRssi                   Int?
  localIp                    String?
  sortOrder                  Int       @default(0)
  isHidden                   Boolean   @default(false)
  localPairingToken          String?
  localPairingTokenUpdatedAt DateTime?
  firmwareVersion            String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  elderProfileId  String
  elderProfile    MsElderProfile           @relation(fields: [elderProfileId], references: [id])
  roomCategoryId  String?
  roomCategory    MsRoomCategory?          @relation(fields: [roomCategoryId], references: [id], onDelete: SetNull)
  commands        TrDeviceCommand[]
  pairingRequests TrDevicePairingRequest[]
  notifications   TrNotification[]
  voiceEmotionLogs TrVoiceEmotionLog[]
  voiceConversationTurns TrVoiceConversationTurn[]
  voiceConfig     MsDeviceVoiceConfig?
  elderReminders TrElderReminder[]
  sceneReminderDeliveries TrSceneReminderDelivery[]

  @@index([sortOrder])
  @@index([roomCategoryId])
  @@map("MsDevice")
}

model TrDeviceCommand {
  id          String              @id @default(cuid())
  commandType DeviceCommandType
  payload     Json
  status      DeviceCommandStatus @default(pending)
  createdAt   DateTime            @default(now())
  deliveredAt DateTime?
  appliedAt   DateTime?

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id])

  @@map("TrDeviceCommand")
}

model TrDevicePairingRequest {
  id        String                     @id @default(cuid())
  status    DevicePairingRequestStatus @default(pending)
  expiresAt DateTime
  decidedAt DateTime?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  requesterId String
  requester   MsUser   @relation("PairingRequester", fields: [requesterId], references: [id])

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, status])
  @@index([requesterId, status])
  @@map("TrDevicePairingRequest")
}

model MsRoomCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String
  sortOrder Int      @default(0)
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeId String?
  home   MsHome?    @relation(fields: [homeId], references: [id], onDelete: Cascade)
  devices MsDevice[]
  scenes  MsScene[]

  @@index([sortOrder])
  @@index([homeId])
  @@unique([homeId, slug])
  @@map("MsRoomCategory")
}

model MsScene {
  id            String           @id @default(cuid())
  name          String
  triggerType   SceneTriggerType
  triggerConfig Json?
  actions       Json?
  isEnabled     Boolean          @default(true)
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  homeId String
  home   MsHome   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  roomCategoryId String?
  roomCategory   MsRoomCategory? @relation(fields: [roomCategoryId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   MsUser?   @relation("SceneCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reminderDeliveries TrSceneReminderDelivery[]

  @@index([homeId, triggerType, sortOrder])
  @@index([roomCategoryId])
  @@map("MsScene")
}

model MsDeviceVoiceConfig {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  language  String   @default("en")
  ttsVoice  String   @default("en-US-JennyNeural")
  ttsRate   String   @default("-5%")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deviceId String   @unique
  device   MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("MsDeviceVoiceConfig")
}

model TrVoiceEmotionLog {
  id             String            @id @default(cuid())
  emotionState   VoiceEmotionState @default(neutral)
  confidence     Float             @default(0)
  transcript     String?
  intent         String?
  responseSource String?
  latencyMs      Float?
  createdAt      DateTime          @default(now())

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([emotionState, createdAt])
  @@map("TrVoiceEmotionLog")
}

model TrVoiceConversationTurn {
  id             String            @id @default(cuid())
  transcript     String
  responseText   String?
  intent         String?
  emotionState   VoiceEmotionState @default(neutral)
  confidence     Float             @default(0)
  responseSource String?
  latencyMs      Float?
  createdAt      DateTime          @default(now())

  elderProfileId String
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([elderProfileId, createdAt])
  @@index([deviceId, createdAt])
  @@map("TrVoiceConversationTurn")
}

model MsElderMemoryFact {
  id          String   @id @default(cuid())
  type        String
  key         String
  value       String
  confidence  Float    @default(0)
  status      String   @default("candidate")
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  elderProfileId String
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  sourceTurnId String?

  @@unique([elderProfileId, key])
  @@index([elderProfileId, type, status])
  @@map("MsElderMemoryFact")
}

model MsElderContextSummary {
  id                String   @id @default(cuid())
  summary           String   @default("")
  safetySummary     String   @default("")
  preferenceSummary String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  elderProfileId String @unique
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  @@map("MsElderContextSummary")
}

model TrElderReminder {
  id                String               @id @default(cuid())
  source            ElderReminderSource  @default(voice)
  title             String
  message           String
  dueAt             DateTime
  timezone          String               @default("Asia/Jakarta")
  recurrenceRule    String?
  status            ElderReminderStatus  @default(pending)
  createdFromTurnId String?
  deliveredAt       DateTime?
  acknowledgedAt    DateTime?
  cancelledAt       DateTime?
  failedAt          DateTime?
  attemptCount      Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  elderProfileId String
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  homeId String?
  home   MsHome? @relation(fields: [homeId], references: [id], onDelete: SetNull)

  @@index([elderProfileId, status, dueAt])
  @@index([deviceId, status, dueAt])
  @@index([homeId, status, dueAt])
  @@map("TrElderReminder")
}

model TrSceneReminderDelivery {
  id             String                    @id @default(cuid())
  deliveryMode   SceneReminderDeliveryMode
  deliveredAt    DateTime                  @default(now())
  acknowledgedAt DateTime?
  createdAt      DateTime                  @default(now())

  sceneId String
  scene   MsScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  elderProfileId String
  elderProfile   MsElderProfile @relation(fields: [elderProfileId], references: [id], onDelete: Cascade)

  deviceId String
  device   MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([sceneId, deliveredAt])
  @@index([elderProfileId, deliveredAt])
  @@index([deviceId, deliveredAt])
  @@map("TrSceneReminderDelivery")
}

model TrNotificationResponse {
  id        String   @id @default(cuid())
  status    String
  note      String?
  createdAt DateTime @default(now())

  notificationId String
  notification   TrNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  userId String
  user   MsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notificationId, createdAt])
  @@map("TrNotificationResponse")
}

model TrNotificationUserState {
  id        String   @id @default(cuid())
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notificationId String
  notification   TrNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  userId String
  user   MsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("TrNotificationUserState")
}

model TrNotification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId String
  user   MsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  homeId String?
  home   MsHome? @relation(fields: [homeId], references: [id], onDelete: Cascade)

  deviceId String?
  device   MsDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  states    TrNotificationUserState[]
  responses TrNotificationResponse[]

  @@index([userId, type, createdAt])
  @@index([homeId])
  @@index([deviceId])
  @@map("TrNotification")
}
