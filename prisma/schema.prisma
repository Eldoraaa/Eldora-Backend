generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  family
  caregiver
  admin
}

enum DeviceCommandType {
  configure_wifi
}

enum DeviceCommandStatus {
  pending
  delivered
  applied
  failed
}

enum DevicePairingRequestStatus {
  pending
  approved
  rejected
  expired
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  googleId  String?  @unique
  name      String
  avatarUrl String?
  role      UserRole @default(family)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  elderProfiles   ElderProfile[]
  pairingRequests DevicePairingRequest[] @relation("PairingRequester")
}

model ElderProfile {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  devices Device[]
}

model Device {
  id                         String    @id @default(cuid())
  deviceId                   String    @unique
  deviceKey                  String    @unique
  name                       String?
  isOnline                   Boolean   @default(false)
  lastSeen                   DateTime?
  batteryLevel               Int?
  isCharging                 Boolean   @default(false)
  wifiSsid                   String?
  wifiRssi                   Int?
  localIp                    String?
  localPairingToken          String?
  localPairingTokenUpdatedAt DateTime?
  firmwareVersion            String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  elderProfileId  String
  elderProfile    ElderProfile           @relation(fields: [elderProfileId], references: [id])
  commands        DeviceCommand[]
  pairingRequests DevicePairingRequest[]
}

model DeviceCommand {
  id          String              @id @default(cuid())
  commandType DeviceCommandType
  payload     Json
  status      DeviceCommandStatus @default(pending)
  createdAt   DateTime            @default(now())
  deliveredAt DateTime?
  appliedAt   DateTime?

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])
}

model DevicePairingRequest {
  id        String                     @id @default(cuid())
  status    DevicePairingRequestStatus @default(pending)
  expiresAt DateTime
  decidedAt DateTime?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  requesterId String
  requester   User   @relation("PairingRequester", fields: [requesterId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId, status])
  @@index([requesterId, status])
}
