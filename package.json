{
  "name": "backend-eldora",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/index.js",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node --files -r tsconfig-paths/register src/index.ts\"",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "prebuild": "npm run prisma:generate",
    "build": "tsc",
    "postbuild": "tsc-alias",
    "start": "node dist/src/index.js",
    "voice:install": "python -m pip install -r voice-service/requirements.txt",
    "voice:dev": "cd voice-service && python -m uvicorn app:app --host 0.0.0.0 --port 8000",
    "seed": "ts-node --files -r tsconfig-paths/register prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
